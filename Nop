	GetSkill_C = function(p191, p192)
		for _, v193 in pairs(game:GetService("Players").LocalPlayer.PlayerGui.Main.Skills:GetChildren()) do
			if v193.Name == p191 then
				if v193:FindFirstChild(p192) then
					if tostring(v193[p192].Title.TextColor) == "Institutional white" then
						if v193[p192].Cooldown.AbsoluteSize.X == 0 then
							return true
						end
					end
				end
			end
		end
		return false
	end
